# 和 server/.env 用同一个 MongoDB
MONGO_URI=mongodb+srv://<user>:<pass>@xishuipang-db-qo1sq.mongodb.net/
MONGO_DB=Xishuipang

# 输出路径（相对 tts/ 目录）
OUTPUT_DIR=output

# MeloTTS 参数
SPEAKER_ID=ZH
SPEED=0.9                  # 朗读式文章稍慢更沉静；1.0 标准，0.8 很慢
BITRATE=32k                # MP3 码率，语音 32k 可听；想更清晰试 64k
OUTPUT_SAMPLE_RATE=22050   # 32k 配 22.05kHz 最清晰；用 64k+ 可改 44100
EN_THRESHOLD=0.7           # 英文字符占比 > 0.7 则用 EN 模型

# 批量处理
WORKERS=1                  # M1 Pro 16GB 建议 1；32GB 可试 2
CHARACTER=simplified       # 只处理简体；繁体在后端映射到同一音频文件
