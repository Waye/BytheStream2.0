# MongoDB Atlas
MONGO_URI=mongodb+srv://<user>:<pass>@xishuipang-db-qo1sq.mongodb.net/
MONGO_DB=Xishuipang

# Redis (可选 — 不配就用内存缓存)
REDIS_URL=

# Server
PORT=4000
HOST=0.0.0.0

# CORS (前端地址,逗号分隔)
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:19000,http://localhost:3000

# ─────────────────── 认证 ───────────────────

# JWT 签名密钥（生产环境务必改成强随机串）
JWT_SECRET=dev-local-secret-change-me
JWT_EXPIRES_IN=30d

# Google OAuth
# 多个 Client ID 用逗号分隔（web/iOS/Android 可全部填进去，verifier 会逐一尝试）
# 拿到方式：console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_IDS=

# Facebook OAuth
# 拿到方式：developers.facebook.com → My Apps → Settings → Basic
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
